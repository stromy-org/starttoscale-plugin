{
  "$schema": "../../../../schema/docx-style-spec.schema.json",
  "spec": "styles",
  "version": "1.0",
  "description": "Brand-token-driven DOCX style base. Materialised to styles.docx by the Workspace Studio `docx` skill via `render-anchors --client <slug>`. Tokens resolve from the brand's charter.json at render time.",
  "page": {
    "size": "{{document.paperSize|A4}}",
    "margins": { "top": "2.5cm", "bottom": "2.5cm", "left": "2.5cm", "right": "2.5cm" }
  },
  "fonts": {
    "heading": { "family": "{{fonts.heading.family}}", "fallback": "{{fonts.heading.fallback}}" },
    "body":    { "family": "{{fonts.body.family}}",    "fallback": "{{fonts.body.fallback}}" },
    "mono":    { "family": "{{fonts.mono.family|fonts.body.family}}", "fallback": "{{fonts.mono.fallback|fonts.body.fallback}}" }
  },
  "colors": {
    "text":      "{{colors.text}}",
    "textLight": "{{colors.textLight}}",
    "accent":    "{{colors.accent}}",
    "primary":   "{{colors.primary}}",
    "rule":      "{{colors.backgroundAlt}}"
  },
  "styles": [
    { "id": "Title",       "basedOn": null,   "font": "heading", "sizePt": 28, "weight": 700, "color": "primary", "spacingAfter": 18 },
    { "id": "Heading1",    "basedOn": "Title","font": "heading", "sizePt": 20, "weight": 700, "color": "primary", "spacingBefore": 18, "spacingAfter": 8 },
    { "id": "Heading2",    "basedOn": null,   "font": "heading", "sizePt": 16, "weight": 600, "color": "primary", "spacingBefore": 14, "spacingAfter": 6 },
    { "id": "Heading3",    "basedOn": null,   "font": "heading", "sizePt": 13, "weight": 600, "color": "text",    "spacingBefore": 10, "spacingAfter": 4 },
    { "id": "BodyText",    "basedOn": null,   "font": "body",    "sizePt": 11, "weight": 400, "color": "text",    "lineSpacing": 1.4, "spacingAfter": 8 },
    { "id": "BodyTextBold","basedOn": "BodyText", "weight": 700 },
    { "id": "Quote",       "basedOn": "BodyText", "italic": true, "color": "text",      "leftIndent": "1cm", "leftBorder": { "color": "accent", "widthPt": 3 } },
    { "id": "Code",        "basedOn": null,   "font": "mono",    "sizePt": 10, "weight": 400, "color": "text" },
    { "id": "Caption",     "basedOn": null,   "font": "body",    "sizePt": 9,  "weight": 400, "italic": true, "color": "textLight" },
    { "id": "FooterText",  "basedOn": null,   "font": "body",    "sizePt": 9,  "weight": 400, "color": "textLight" }
  ]
}
